# SVI Engine microservice
PORT=4013

# Shared secret — callers must send X-Internal-Key: <SVI_SECRET>
SVI_SECRET=change-me-in-production

# Auth service (API key validation for partner endpoints)
AUTH_SERVICE_URL=http://blockid-auth:4012
AUTH_SECRET=change-me-in-production

# Billing service (credit checks for partner endpoints)
BILLING_URL=http://blockid-billing:4011
BILLING_SECRET=change-me-in-production

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Logging
LOG_LEVEL=info
