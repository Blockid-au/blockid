# BlockID.au Production Cron Schedule
# ====================================
# All times in UTC. Server is in UTC, users in AEST (UTC+10).
# AI tasks run off-peak: 10pm-6am AEST = 12pm-8pm UTC (previous day)
#
# RATE LIMIT MANAGEMENT:
#   - Claude CLI OAuth: ~50 req/hr (subscription, no cost)
#   - Gemini Flash: 15 RPM free tier
#   - Groq: 30 RPM free tier
#   - Agent-upgrade has 60s delay between AI tasks
#   - Max 3 AI tasks per agent-upgrade run
#   - Total AI requests/day: ~3-5 (well within limits)
#
# CRON_SECRET must be set in environment
# Install: crontab scripts/crontab.production

CRON_SECRET=4b76f13574efd401640cb5dce996f01aa8b8169c02cb1b1949ceb6354ee15f32
BASE=https://blockid.au/api/cron

# ─── Every 5 minutes ──────────────────────────────────────────────
# Blockchain sync (no AI, just DB queue processing)
*/5 * * * * curl -s -X POST "$BASE/blockchain-sync" -H "Authorization: Bearer $CRON_SECRET" > /dev/null 2>&1

# ─── Every 3 hours ────────────────────────────────────────────────
# AI health check (no AI calls, just checks provider availability)
0 */3 * * * curl -s -X POST "$BASE/ai-health" -H "Authorization: Bearer $CRON_SECRET" > /dev/null 2>&1

# ─── Daily at 2am AEST (4pm UTC previous day) ────────────────────
# SVI snapshot (no AI — DB aggregation only)
0 16 * * * curl -s -X POST "$BASE/svi-snapshot" -H "Authorization: Bearer $CRON_SECRET" > /dev/null 2>&1

# SVI notifications (no AI — checks score changes, sends alerts)
5 16 * * * curl -s -X POST "$BASE/svi-notify" -H "Authorization: Bearer $CRON_SECRET" > /dev/null 2>&1

# Nurture emails (no AI — template-based email sequences)
10 16 * * * curl -s -X POST "$BASE/nurture" -H "Authorization: Bearer $CRON_SECRET" > /dev/null 2>&1

# Vesting schedule processing (no AI — monthly vesting computation)
15 16 * * * curl -s -X POST "$BASE/vesting" -H "Authorization: Bearer $CRON_SECRET" > /dev/null 2>&1

# ─── Daily at 3am AEST (5pm UTC) — Agent upgrade (staggered AI) ──
# Contains 13 tasks. Non-AI tasks run instantly.
# AI tasks (3 max) have 60s gap between them = ~3 min total.
# Off-peak check ensures no user-facing AI impact.
0 17 * * * curl -s -X POST "$BASE/agent-upgrade" -H "Authorization: Bearer $CRON_SECRET" > /dev/null 2>&1

# ─── Daily at 4am AEST (6pm UTC) ─────────────────────────────────
# Growth insights (may use AI for recommendations — 1 call max)
0 18 * * * curl -s -X POST "$BASE/growth-insights" -H "Authorization: Bearer $CRON_SECRET" > /dev/null 2>&1

# ─── Daily at 5am AEST (7pm UTC) ─────────────────────────────────
# SVI review (no AI — quality checks on recent analyses)
0 19 * * * curl -s -X POST "$BASE/svi-review" -H "Authorization: Bearer $CRON_SECRET" > /dev/null 2>&1

# ─── Weekly Monday 6am AEST (8pm UTC Sunday) ─────────────────────
# Weekly insights report (may use AI — 1 call max)
0 20 * * 0 curl -s -X POST "$BASE/weekly-insights" -H "Authorization: Bearer $CRON_SECRET" > /dev/null 2>&1

# ─── Publish insight articles (no AI — publishes scheduled content)
# Daily at 7am AEST (9pm UTC) — good time for AU audience
0 21 * * * curl -s -X POST "$BASE/publish-insight" -H "Authorization: Bearer $CRON_SECRET" > /dev/null 2>&1

# ====================================
# RATE LIMIT SUMMARY:
# ────────────────────────────────────
# Time (AEST)  | Cron Job              | AI Calls
# ────────────────────────────────────
# 2:00am       | svi-snapshot          | 0
# 2:05am       | svi-notify            | 0
# 2:10am       | nurture               | 0
# 2:15am       | vesting               | 0
# 3:00am       | agent-upgrade         | 3 max (60s gaps)
# 4:00am       | growth-insights       | 0-1
# 5:00am       | svi-review            | 0
# 6:00am (Mon) | weekly-insights       | 0-1
# 7:00am       | publish-insight       | 0
# Every 3h     | ai-health             | 0
# Every 5m     | blockchain-sync       | 0
# ────────────────────────────────────
# Total AI calls/day: 3-5 (well within 50/hr limit)
# Peak AI window: 3:00-3:05am AEST (3 calls with 60s gaps)
# User-facing AI: unaffected (separate request pool)
