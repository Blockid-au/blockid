# BlockID.au — Production Cron Schedule (Single Source of Truth)
# ======================================
# All times in UTC. Server in UTC, users in AEST (UTC+10).
#
# IMPORTANT: Edit THIS file, then apply with:
#   crontab /home/dovanlong/blockid.au/web/scripts/crontab.production
#
# All API endpoints use cron-runner.sh for:
#   ✅ Logging every run to /tmp/blockid-cron.log
#   ✅ Structured health log → content/reports/cron-health.jsonl
#   ✅ Telegram alert on failure
#   ✅ Auto log rotation (200KB cap)

CRON_SECRET=4b76f13574efd401640cb5dce996f01aa8b8169c02cb1b1949ceb6354ee15f32
RUN=/home/dovanlong/blockid.au/web/scripts/cron-runner.sh

# ═══════════════════════════════════════════════════════════════════
# SYSTEM (no AI, infrastructure only)
# ═══════════════════════════════════════════════════════════════════

# Watchdog — auto-restart if production is dead
*/2 * * * * /home/dovanlong/blockid.au/web/scripts/watchdog.sh

# Cloudflare DDNS — keep DNS pointing to this server
*/5 * * * * /usr/local/bin/cloudflare-ddns-update.sh >> /var/log/cloudflare-ddns.log 2>&1

# AI token guardian — refresh Claude OAuth + provider keys
*/30 * * * * /home/dovanlong/blockid.au/web/scripts/ai-token-guardian.sh >> /tmp/ai-guardian.log 2>&1

# Token refresh — OAuth tokens (Google, GitHub, etc.)
0 */4 * * * /home/dovanlong/blockid.au/scripts/refresh-tokens.sh >> /tmp/blockid-token-refresh.log 2>&1

# Blockchain sync — process DB queue (no AI)
*/15 * * * * bash $RUN blockchain-sync

# AI health check — test provider availability (no AI calls)
0 */3 * * * bash $RUN ai-health

# Git Sync — pull from GitHub + push local commits + deploy if new
# Runs every 30 min to catch manual GitHub pushes or external PRs
*/30 * * * * /home/dovanlong/blockid.au/web/scripts/git-sync-deploy.sh

# ═══════════════════════════════════════════════════════════════════
# DAILY PIPELINE — 2am-9:30am AEST (4pm-11:30pm UTC)
#
# Flow: Data → Health → Research → Improve → Deploy → Report
# ═══════════════════════════════════════════════════════════════════

# ── Phase 1: Data Collection (2:00-2:30am AEST) ─────────────────
# SVI snapshot — save daily SVI + index values for all accounts
0 16 * * * bash $RUN svi-snapshot

# SVI notifications — lifecycle milestone check
5 16 * * * bash $RUN svi-notify

# Nurture (disabled — lifecycle emails only via weekly-insights)
10 16 * * * bash $RUN nurture

# Vesting schedule processing
15 16 * * * bash $RUN vesting

# ── Phase 2: Agent Health & Metrics (3:00am AEST) ───────────────
# Agent upgrade — health checks, metrics collection, daily reports
0 17 * * * bash $RUN agent-upgrade --timeout 120

# ── Phase 3: Intelligence Gathering (4:00-6:00am AEST) ──────────
# Growth insights — analyze growth patterns
0 18 * * * bash $RUN growth-insights --timeout 120

# SVI review — quality checks on analyses
0 19 * * * bash $RUN svi-review

# Agent research — C-Level agents gather fresh knowledge (AI)
0 20 * * * bash $RUN agent-research --timeout 300

# ── Phase 4: Auto-Improve & Deploy (7:00am AEST) ────────────────
# Agent auto-improve — read research → generate code → CI/CD → deploy → GitHub
0 21 * * * bash $RUN agent-auto-improve --timeout 300

# Refresh free AI models — discover top-5 per provider
5 21 * * * bash $RUN refresh-models

# Publish insight articles — AI-generated content
30 21 * * * bash $RUN publish-insight --timeout 120

# ── Phase 5: Reporting (8:00-9:30am AEST) ────────────────────────
# Daily admin report — email + Telegram summary
0 22 * * * bash $RUN daily-admin-report

# QA Agent healthcheck — full test/fix + report (8:30am AEST)
30 22 * * * bash $RUN agent-healthcheck --timeout 180

# Telegram daily report — C-Level agent status + prod health + deploys
30 23 * * * bash $RUN telegram-report

# ═══════════════════════════════════════════════════════════════════
# WEEKLY — Sunday only
# ═══════════════════════════════════════════════════════════════════

# 6:30am AEST Sunday — Lifecycle follow-up emails (1w/1m/3m milestones)
30 20 * * 0 bash $RUN weekly-insights --timeout 120

# ═══════════════════════════════════════════════════════════════════
# SELF-HEALING: Daily cron health check
# Runs at 11:30pm UTC (9:30am AEST) — AFTER all daily routines
# ═══════════════════════════════════════════════════════════════════
30 23 * * * bash $RUN cron-health

# ═══════════════════════════════════════════════════════════════════
# DAILY PIPELINE DIAGRAM
# ═══════════════════════════════════════════════════════════════════
#
#   2:00am ─── Data Collection ──┐
#   │ svi-snapshot                │
#   │ svi-notify                  │
#   │ vesting                     │
#   │                             ▼
#   3:00am ─── Agent Health ─────┐
#   │ agent-upgrade (metrics)    │
#   │ → saves daily reports      │
#   │                             ▼
#   4:00am ─── Intelligence ─────┐
#   │ growth-insights            │
#   │ svi-review                 │
#   │ agent-research (AI)        │
#   │ → knowledge_base update    │
#   │                             ▼
#   7:00am ─── Auto-Improve ─────┐   ◄── NEW: the automation loop
#   │ agent-auto-improve (AI)    │
#   │ → reads research           │
#   │ → generates code           │
#   │ → runs CI gates (tsc/lint) │
#   │ → deploys via deploy-live  │
#   │ → pushes to GitHub         │
#   │ refresh-models             │
#   │ publish-insight            │
#   │                             ▼
#   8:00am ─── Reporting ─────────┐
#   │ daily-admin-report         │
#   │ telegram-report            │
#   │ cron-health                │
#   └─────────────────────────────┘
#
# CONTINUOUS (every 30 min):
#   git-sync-deploy — pull GitHub → deploy if new commits
#   (catches manual pushes, external PRs, agent deployments)
#
# ═══════════════════════════════════════════════════════════════════
