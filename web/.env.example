# ----------------------------------------------------------------------------
# BlockID — environment variables
# Copy to `.env` for local development or `.env.production` on the VPS.
# Never commit a populated copy of this file.
# ----------------------------------------------------------------------------

# --- Runtime ---------------------------------------------------------------
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# --- Public site URL (used for share links + email links) -----------------
# In dev: http://localhost:3000
# In prod: https://blockid.au
NEXT_PUBLIC_SITE_URL=https://blockid.au

# --- Supabase (server-only) ------------------------------------------------
# Create a project at https://supabase.com and copy these from
# Project Settings → API. The service-role key bypasses RLS — never expose it
# to the browser. Only the Next.js server uses it.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Email (Resend, server-only) ------------------------------------------
# Create at https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=BlockID <noreply@blockid.au>

# --- IP hashing salt (rotate periodically) --------------------------------
# Used to hash viewer IPs for /s/[slug] view counting without storing raw IPs.
# Any random 32+ char string works. If unset, a daily-rotating default is used.
IP_HASH_SALT=

# --- AI providers (priority: Claude CLI OAuth > ANTHROPIC_API_KEY > Gemini) --
# Claude: get API key at https://console.anthropic.com
# Or use Claude CLI OAuth (auto-detected from ~/.claude/.credentials.json)
ANTHROPIC_API_KEY=

# Google Gemini — free-tier fallback when Claude is unavailable
# Get at https://aistudio.google.com/apikey (account: ceo@longcare.au)
GOOGLE_GEMINI_API_KEY=

# --- Google OAuth (Sign In With Google) -----------------------------------
# Create a Google Cloud Project, enable Google Identity Services API,
# and create a Web Application OAuth 2.0 credential.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID is exposed to the browser for the GSI button.
# GOOGLE_CLIENT_ID is used server-side to verify the token audience.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# --- Google Drive API (Evidence Upload + Project Documents) ---------------
# Create a Service Account in the same GCP project, enable Drive API,
# and generate a JSON key. Share a Google Drive folder with the SA email.
# Files uploaded by users are automatically shared with admin@blockid.au.
GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=
GOOGLE_DRIVE_FOLDER_ID=

# --- Stripe (payments) ----------------------------------------------------
# Create at https://dashboard.stripe.com/apikeys
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY is exposed to the browser for Stripe.js.
# STRIPE_SECRET_KEY is server-only — never expose it.
# STRIPE_WEBHOOK_SECRET is the signing secret for /api/stripe/webhook.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — create Products + Prices in Stripe Dashboard, then
# paste the price_xxx IDs here.
STRIPE_PRICE_FOUNDING50=
STRIPE_PRICE_FOUNDER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PILOT=
STRIPE_PRICE_ACCELERATOR=

# --- Cron Secret (protects /api/cron/* endpoints) -------------------------
CRON_SECRET=
