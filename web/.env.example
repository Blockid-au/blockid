# ----------------------------------------------------------------------------
# BlockID — environment variables
# Copy to `.env` for local development or `.env.production` on the VPS.
# Never commit a populated copy of this file.
# ----------------------------------------------------------------------------

# --- Runtime ---------------------------------------------------------------
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# --- Public site URL (used for share links + email links) -----------------
# In dev: http://localhost:3000
# In prod: https://blockid.au
NEXT_PUBLIC_SITE_URL=https://blockid.au

# --- Supabase (server-only) ------------------------------------------------
# Create a project at https://supabase.com and copy these from
# Project Settings → API. The service-role key bypasses RLS — never expose it
# to the browser. Only the Next.js server uses it.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Email (Resend, server-only) ------------------------------------------
# Create at https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=BlockID <noreply@blockid.au>

# --- IP hashing salt (rotate periodically) --------------------------------
# Used to hash viewer IPs for /s/[slug] view counting without storing raw IPs.
# Any random 32+ char string works. If unset, a daily-rotating default is used.
IP_HASH_SALT=

# --- AI providers (auto-fallback chain) -----------------------------------
# Priority: Claude CLI OAuth > ANTHROPIC_API_KEY > Claude Proxy > Codex > OpenAI > Gemini
# If the primary provider fails, the system tries the next one automatically.
#
# Claude: CLI OAuth auto-detected from ~/.claude/.credentials.json
# Or get API key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Anthropic-compatible proxy (third-party relay, e.g. TapHoaAPI)
# Supports same /v1/messages API as Anthropic. Comma-separated keys for auto-rotate.
ANTHROPIC_PROXY_BASE_URL=
ANTHROPIC_PROXY_API_KEY=

# OpenAI: get API key at https://platform.openai.com/api-keys
# Uses gpt-4o-mini (cost-effective, fast)
OPENAI_API_KEY=

# Google Gemini: free-tier fallback (last resort)
# Get at https://aistudio.google.com/apikey (account: ceo@longcare.au)
GOOGLE_GEMINI_API_KEY=

# Codex CLI access token (auto-detected from ~/.codex/auth.json)
# CODEX_ACCESS_TOKEN=

# --- Google OAuth (Sign In With Google) -----------------------------------
# Create a Google Cloud Project, enable Google Identity Services API,
# and create a Web Application OAuth 2.0 credential.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID is exposed to the browser for the GSI button.
# GOOGLE_CLIENT_ID is used server-side to verify the token audience.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# --- Google Analytics OAuth (Evidence Vault — Connect Analytics) ----------
# Uses the same Google OAuth client as Sign-In.
# Add callback URL to Authorized redirect URIs in GCP Console:
#   https://blockid.au/api/auth/analytics/callback
#   https://dev.blockid.au/api/auth/analytics/callback
# GOOGLE_CLIENT_SECRET is needed for the token exchange.
GOOGLE_CLIENT_SECRET=

# --- Google Drive API (Evidence Upload + Project Documents) ---------------
# Create a Service Account in the same GCP project, enable Drive API,
# and generate a JSON key. Share a Google Drive folder with the SA email.
# Files uploaded by users are automatically shared with admin@blockid.au.
GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=
GOOGLE_DRIVE_FOLDER_ID=

# --- Stripe (payments) ----------------------------------------------------
# Create at https://dashboard.stripe.com/apikeys
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY is exposed to the browser for Stripe.js.
# STRIPE_SECRET_KEY is server-only — never expose it.
# STRIPE_WEBHOOK_SECRET is the signing secret for /api/stripe/webhook.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — create Products + Prices in Stripe Dashboard, then
# paste the price_xxx IDs here.
STRIPE_PRICE_FOUNDING50=
STRIPE_PRICE_FOUNDER=
STRIPE_PRICE_GROWTH=
# $499/mo standard Growth price (used after July 1, 2026 early-bird deadline)
STRIPE_PRICE_GROWTH_499=
STRIPE_PRICE_PILOT=
STRIPE_PRICE_ACCELERATOR=

# Credit pack pricing (one-off purchases — fractional credit system)
STRIPE_PRICE_CREDITS_5=
STRIPE_PRICE_CREDITS_10=
STRIPE_PRICE_CREDITS_25=
STRIPE_PRICE_CREDITS_50=
STRIPE_PRICE_CREDITS_100=

# Per-analysis SVI pricing
# A$1 AUD early-bird price (until June 15, 2026)
STRIPE_PRICE_SVI_ANALYSIS=
# $25 AUD standard price (after June 15, 2026)
STRIPE_PRICE_SVI_ANALYSIS_25=

# --- SMTP (optional Gmail relay fallback if Resend unavailable) -----------
# Set up Gmail App Password: Google Account → Security → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=

# --- ElevenLabs (AI Voice Synthesis for pitch videos) ---------------------
# Get at https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9

# --- Google Analytics (GA4) + Tag Manager ---------------------------------
# Create a GA4 property at https://analytics.google.com (account: ceo@longcare.au)
# Measurement ID looks like G-XXXXXXXXXX — found in Admin → Data Streams.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Tag Manager (optional) — container ID like GTM-XXXXXXX.
# If set, GTM container is loaded alongside GA4. Configure goals, triggers
# and third-party tags in GTM instead of code. https://tagmanager.google.com
NEXT_PUBLIC_GTM_ID=

# --- Google Search Console ------------------------------------------------
# Verification code from https://search.google.com/search-console
# Use the "HTML tag" method → copy only the content="xxx" value.
NEXT_PUBLIC_GSC_VERIFICATION=

# --- GitHub OAuth (Evidence Vault — Connect GitHub) -----------------------
# Create at https://github.com/settings/developers → OAuth Apps
# Callback URL: https://blockid.au/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Cron Secret (protects /api/cron/* endpoints) -------------------------
CRON_SECRET=
