# Version control
.git
.gitignore
.gitattributes

# Dependencies / build output (rebuilt inside the image)
node_modules
.next
out
dist
build
coverage

# Local env files.
# .env IS included so Next.js reads NEXT_PUBLIC_* at build time (client inlining).
# Multi-stage build: .env only exists in builder stage, NOT in final runtime image.
# Runtime secrets are injected via --env-file at docker run.
.env.local
.env.development
.env.staging
!.env.example

# Editor / OS cruft
.vscode
.idea
.DS_Store
Thumbs.db
*.swp
*.swo

# Logs / caches
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.pnpm-store
.turbo
.cache

# Docs (built by another agent, not needed in image)
README.md
*.md
docs

# Sibling directories that shouldn't ship with the app image
design-system

# Infra / CI artifacts
infra
docker-compose.yml
docker-compose.*.yml
Dockerfile
.dockerignore

# Test files
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
__tests__
e2e
playwright-report
test-results
